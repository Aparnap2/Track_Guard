# Sarthi AI Service - Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git!

# =============================================================================
# LLM Configuration (v4.2 factory pattern)
# =============================================================================
# All LLM access goes through src/config/llm.py factory.
# No direct AzureOpenAI instantiation in agents.
# Provider priority: Groq (GROQ_API_KEY) → OpenRouter → Ollama

GROQ_API_KEY=your-groq-api-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=qwen/qwen3-32b
LLM_MODEL=qwen/qwen3-32b
LLM_PROVIDER=groq

OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-ada-002

# =============================================================================
# Qdrant Vector Database
# =============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333

# =============================================================================
# PostgreSQL Database
# =============================================================================
DATABASE_URL=postgres://iterateswarm:iterateswarm@localhost:5432/iterateswarm?sslmode=disable

# =============================================================================
# Temporal Workflow Engine
# =============================================================================
TEMPORAL_ADDRESS=localhost:7233

# =============================================================================
# Neo4j Graph Database (for Graphiti memory)
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=saarathi

# =============================================================================
# Development & Test Mode
# =============================================================================
DEV_MODE=true
TEST_MODE=true
