{
  "uuid": "sarthi-test-env",
  "name": "Sarthi Slackbot Test Environment",
  "version": "2.0.0",
  "port": 3333,
  "routes": [
    {
      "uuid": "health-check",
      "documentation": "Health check endpoint for service status",
      "method": "get",
      "endpoint": "/health",
      "response": {
        "uuid": "health-response",
        "labels": [],
        "latency": 0,
        "statusCode": 200,
        "body": "{\n  \"status\": \"ok\",\n  \"service\": \"sarthi-core-mock\",\n  \"time\": \"{{timestamp}}\"\n}",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "uuid": "hitl-investigate",
      "documentation": "HITL investigate endpoint for human-in-the-loop workflow",
      "method": "post",
      "endpoint": "/internal/hitl/investigate",
      "body": true,
      "bodyType": "json",
      "response": {
        "uuid": "investigate-response",
        "labels": [],
        "latency": 0,
        "statusCode": 200,
        "body": "{\n  \"ok\": true,\n  \"action\": \"investigate\",\n  \"workflow_id\": \"{{jsonPath 'workflow_id' body}}\",\n  \"message\": \"Investigation queued for human review\"\n}",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "uuid": "hitl-dismiss",
      "documentation": "HITL dismiss endpoint to dismiss an alert",
      "method": "post",
      "endpoint": "/internal/hitl/dismiss",
      "body": true,
      "bodyType": "json",
      "response": {
        "uuid": "dismiss-response",
        "labels": [],
        "latency": 0,
        "statusCode": 200,
        "body": "{\n  \"ok\": true,\n  \"action\": \"dismiss\",\n  \"workflow_id\": \"{{jsonPath 'workflow_id' body}}\",\n  \"message\": \"Alert dismissed\"\n}",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "uuid": "bi-query",
      "documentation": "BI query endpoint for natural language data queries",
      "method": "post",
      "endpoint": "/internal/query",
      "body": true,
      "bodyType": "json",
      "response": {
        "uuid": "query-response",
        "labels": [],
        "latency": 0,
        "statusCode": 202,
        "body": "{\n  \"ok\": true,\n  \"workflow_id\": \"wf-{{uuid}}\",\n  \"query_id\": \"q-{{uuid}}\",\n  \"message\": \"Query accepted for async processing\"\n}",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "uuid": "slack-events-webhook",
      "documentation": "Slack Events API webhook receiver for URL verification and message events",
      "method": "post",
      "endpoint": "/slack/events",
      "body": true,
      "bodyType": "json",
      "response": {
        "uuid": "events-response",
        "labels": [],
        "latency": 0,
        "statusCode": 200,
        "body": "{{json (case (jsonPath 'type' body) 'url_verification' (ternary (responseFromTemplate '{}' (object 'ok' true 'challenge' (jsonPath 'challenge' body))) (object 'ok' true)) 'type')}}",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "uuid": "chat-postmessage",
      "documentation": "Slack chat.postMessage API for sending messages to channels",
      "method": "post",
      "endpoint": "/api/chat.postMessage",
      "body": true,
      "bodyType": "json",
      "response": {
        "uuid": "postmessage-response",
        "labels": [],
        "latency": 0,
        "statusCode": 200,
        "body": "{\n  \"ok\": true,\n  \"channel\": \"{{jsonPath 'channel' body}}\",\n  \"ts\": \"1234567890.123456\",\n  \"message\": {\n    \"type\": \"message\",\n    \"channel\": \"{{jsonPath 'channel' body}}\",\n    \"user\": \"U0000000\",\n    \"text\": \"{{jsonPath 'text' body}}\",\n    \"ts\": \"1234567890.123456\"\n  }\n}",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "uuid": "conversations-history",
      "documentation": "Slack conversations.history API for fetching message history",
      "method": "get",
      "endpoint": "/api/conversations.history",
      "response": {
        "uuid": "history-response",
        "labels": [],
        "latency": 0,
        "statusCode": 200,
        "body": "{\n  \"ok\": true,\n  \"has_more\": false,\n  \"messages\": [\n    {\n      \"type\": \"message\",\n      \"channel\": \"C123456789\",\n      \"user\": \"U0000001\",\n      \"text\": \"Hello from test user\",\n      \"ts\": \"1234567890.000001\",\n      \"thread_ts\": null\n    },\n    {\n      \"type\": \"message\",\n      \"channel\": \"C123456789\",\n      \"user\": \"U0000002\",\n      \"text\": \"Another test message\",\n      \"ts\": \"1234567890.000002\",\n      \"thread_ts\": \"1234567890.000001\"\n    }\n  ]\n}",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "uuid": "llm-chat-completions",
      "documentation": "OpenAI-compatible chat completions mock for Guardian agents",
      "method": "post",
      "endpoint": "/api/llm/chat/completions",
      "body": true,
      "bodyType": "json",
      "response": {
        "uuid": "completions-response",
        "labels": [],
        "latency": 0,
        "statusCode": 200,
        "body": "{\n  \"id\": \"chatcmpl-mock-test-001\",\n  \"object\": \"chat.completion\",\n  \"created\": 1234567890,\n  \"model\": \"{{jsonPath 'model' body}}\",\n  \"choices\": [\n    {\n      \"index\": 0,\n      \"message\": {\n        \"role\": \"assistant\",\n        \"content\": \"Guardian insight: Based on the analysis, this request requires attention. The system has processed the input and determined the appropriate response path. Priority level: normal.\"\n      },\n      \"finish_reason\": \"stop\"\n    }\n  ],\n  \"usage\": {\n    \"prompt_tokens\": 50,\n    \"completion_tokens\": 35,\n    \"total_tokens\": 85\n  }\n}",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "uuid": "slack-deliver",
      "documentation": "Demo delivery endpoint for Sarthi webhook testing",
      "method": "post",
      "endpoint": "/slack/deliver",
      "body": true,
      "bodyType": "json",
      "response": {
        "uuid": "deliver-response",
        "labels": [],
        "latency": 0,
        "statusCode": 200,
        "body": "{\n  \"ok\": true,\n  \"delivered\": true,\n  \"message_id\": \"mock-msg-001\",\n  \"delivered_at\": \"2026-04-27T12:00:00Z\"\n}",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "uuid": "telegram-send-message",
      "documentation": "Telegram sendMessage API for sending text messages",
      "method": "post",
      "endpoint": "/bot:test-token/sendMessage",
      "body": true,
      "bodyType": "json",
      "response": {
        "uuid": "telegram-msg-response",
        "labels": [],
        "latency": 0,
        "statusCode": 200,
        "body": "{\n  \"ok\": true,\n  \"result\": {\n    \"message_id\": 1,\n    \"chat\": {\n      \"id\": {{jsonPath 'chat_id' body}},\n      \"type\": \"private\"\n    },\n    \"text\": \"{{jsonPath 'text' body}}\"\n  }\n}",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "uuid": "telegram-send-photo",
      "documentation": "Telegram sendPhoto API for sending images",
      "method": "post",
      "endpoint": "/bot:test-token/sendPhoto",
      "body": true,
      "bodyType": "json",
      "response": {
        "uuid": "telegram-photo-response",
        "labels": [],
        "latency": 0,
        "statusCode": 200,
        "body": "{\n  \"ok\": true,\n  \"result\": {\n    \"message_id\": 2,\n    \"chat\": {\n      \"id\": {{jsonPath 'chat_id' body}},\n      \"type\": \"private\"\n    },\n    \"photo\": {\n      \"file_id\": \"AgACAgIAAxkBAAIB\"\n    }\n  }\n}",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    }
  ],
  "proxyMode": false,
  "cors": true,
  "corsAllowCredentials": false,
  "corsAllowOrigin": "*",
  "corsAllowMethods": "GET, POST, PUT, PATCH, DELETE, OPTIONS, HEAD",
  "corsAllowHeaders": "Content-Type, Authorization, X-Slack-Signature, X-Slack-Request-Timestamp",
  "corsExposeHeaders": "",
  "corsMaxAge": 0
}